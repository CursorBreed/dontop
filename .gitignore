# Signing keys — never commit
android/key.properties
android/**/*.keystore
android/**/*.jks

# Gradle
android/.gradle/
android/gradle-wrapper.jar
android/gradlew
android/gradlew.bat
android/captures/
android/.cxx/

# Generated plugin registrant
android/app/src/main/java/io/flutter/plugins/GeneratedPluginRegistrant.java

